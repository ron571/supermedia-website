# Upstash Redis — rate limiting + brief storage
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_SALT=

# Admin area — set a strong password and a random token string
ADMIN_PASSWORD=
ADMIN_TOKEN=

# Public
NEXT_PUBLIC_SITE_URL=https://supermedia.co.nz
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/ron-supermedia
